# Copy this to .env.local and fill in real values

# Cloudinary — get from cloudinary.com > Settings > API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin password for the upload page
ADMIN_PASSWORD=choose_a_strong_password

# JWT signing secret — must be at least 32 random bytes
# Generate one with: openssl rand -base64 32
JWT_SECRET=a_random_32_char_string_here
